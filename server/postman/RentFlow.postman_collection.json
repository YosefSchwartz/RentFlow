{
  "info": {
    "name": "RentFlow API",
    "description": "Property management platform API - A user can be both a property owner AND a tenant",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "propertyId",
      "value": "",
      "type": "string"
    },
    {
      "key": "leaseId",
      "value": "",
      "type": "string"
    },
    {
      "key": "invitationCode",
      "value": "",
      "type": "string"
    },
    {
      "key": "documentId",
      "value": "",
      "type": "string"
    },
    {
      "key": "requestId",
      "value": "",
      "type": "string"
    },
    {
      "key": "tenantId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken', response.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"password\": \"password123\",\n  \"firstName\": \"New\",\n  \"lastName\": \"User\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            },
            "description": "Register a new user account (no role - users can be both owners and tenants)"
          }
        },
        {
          "name": "Login as Owner",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken', response.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"owner@example.com\",\n  \"password\": \"owner123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Login as property owner (seeded user)"
          }
        },
        {
          "name": "Login as Tenant",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken', response.accessToken);",
                  "    pm.collectionVariables.set('tenantId', response.user.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tenant@example.com\",\n  \"password\": \"tenant123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Login as tenant (seeded user)"
          }
        }
      ],
      "description": "Authentication endpoints"
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            },
            "description": "Get the currently authenticated user's profile"
          }
        },
        {
          "name": "Get Dashboard",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/me/dashboard",
              "host": ["{{baseUrl}}"],
              "path": ["me", "dashboard"]
            },
            "description": "Get user dashboard with owned properties count, active leases count, and access flags"
          }
        }
      ],
      "description": "User management endpoints"
    },
    {
      "name": "Properties",
      "item": [
        {
          "name": "Create Property",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('propertyId', response.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Modern Downtown Apartment\",\n  \"address\": \"456 Main Street, Apt 12\",\n  \"city\": \"Tel Aviv\",\n  \"squareMeters\": 75,\n  \"rooms\": 3,\n  \"floor\": 5,\n  \"hasBalcony\": true,\n  \"hasParking\": true,\n  \"hasStorage\": false,\n  \"notes\": \"Recently renovated with new appliances\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/properties",
              "host": ["{{baseUrl}}"],
              "path": ["properties"]
            },
            "description": "Create a new property (any user can own properties)"
          }
        },
        {
          "name": "List Properties",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/properties",
              "host": ["{{baseUrl}}"],
              "path": ["properties"]
            },
            "description": "List all properties (owned and rented) for the current user"
          }
        },
        {
          "name": "Get Property",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/properties/{{propertyId}}",
              "host": ["{{baseUrl}}"],
              "path": ["properties", "{{propertyId}}"]
            },
            "description": "Get details of a specific property"
          }
        },
        {
          "name": "Update Property",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Apartment Name\",\n  \"notes\": \"Updated notes about the property\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/properties/{{propertyId}}",
              "host": ["{{baseUrl}}"],
              "path": ["properties", "{{propertyId}}"]
            },
            "description": "Update a property (owner only)"
          }
        },
        {
          "name": "Delete Property",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/properties/{{propertyId}}",
              "host": ["{{baseUrl}}"],
              "path": ["properties", "{{propertyId}}"]
            },
            "description": "Delete a property (owner only)"
          }
        }
      ],
      "description": "Property management endpoints"
    },
    {
      "name": "Leases",
      "item": [
        {
          "name": "Create Lease",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('leaseId', response.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantId\": \"{{tenantId}}\",\n  \"startDate\": \"2024-01-01\",\n  \"endDate\": \"2024-12-31\",\n  \"monthlyRent\": 5000,\n  \"depositAmount\": 15000,\n  \"notes\": \"One year lease agreement\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/properties/{{propertyId}}/leases",
              "host": ["{{baseUrl}}"],
              "path": ["properties", "{{propertyId}}", "leases"]
            },
            "description": "Create a new lease for a property (property owner only)"
          }
        },
        {
          "name": "List Property Leases",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/properties/{{propertyId}}/leases",
              "host": ["{{baseUrl}}"],
              "path": ["properties", "{{propertyId}}", "leases"]
            },
            "description": "List all leases for a property (property owner only)"
          }
        },
        {
          "name": "Get My Leases",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/leases/my",
              "host": ["{{baseUrl}}"],
              "path": ["leases", "my"]
            },
            "description": "Get all leases for the current user (as tenant)"
          }
        },
        {
          "name": "Update Lease Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"ENDED\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/leases/{{leaseId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["leases", "{{leaseId}}", "status"]
            },
            "description": "Update lease status (property owner only). Status: PENDING, ACTIVE, ENDED"
          }
        }
      ],
      "description": "Lease management - represents rental agreements between tenants and properties"
    },
    {
      "name": "Invitations",
      "item": [
        {
          "name": "Create Invitation",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('invitationCode', response.code);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/properties/{{propertyId}}/invite",
              "host": ["{{baseUrl}}"],
              "path": ["properties", "{{propertyId}}", "invite"]
            },
            "description": "Generate an invitation code for a property (owner only)"
          }
        },
        {
          "name": "List Property Invitations",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/properties/{{propertyId}}/invitations",
              "host": ["{{baseUrl}}"],
              "path": ["properties", "{{propertyId}}", "invitations"]
            },
            "description": "List all invitations for a property (owner only)"
          }
        },
        {
          "name": "Accept Invitation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"{{invitationCode}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tenants/accept",
              "host": ["{{baseUrl}}"],
              "path": ["tenants", "accept"]
            },
            "description": "Accept an invitation to join a property (any user can be a tenant)"
          }
        },
        {
          "name": "Revoke Invitation",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/invitations/{{invitationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["invitations", "{{invitationId}}"]
            },
            "description": "Revoke an invitation (owner only)"
          }
        }
      ],
      "description": "Tenant invitation management (onboarding flow)"
    },
