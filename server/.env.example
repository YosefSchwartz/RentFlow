# ============================================
# RentFlow — environment template
# ============================================
# Copy to `.env` (local dev / LocalStack) or inject these as real environment
# variables in production. Developer-specific overrides can go in `.env.local`
# (gitignored, loaded with higher precedence than `.env`).

# Database
DATABASE_URL="postgresql://keynest:keynest_secret@localhost:5432/keynest?schema=public"

# Auth / sessions
# Secret used to sign access tokens. Token lifetimes are managed in code:
# 15-minute access tokens + 30-day rotating refresh tokens (DB-backed sessions),
# so there is no TTL env knob. Keep this secret strong and unique per environment.
JWT_SECRET="change-me"

# Secret used to HMAC-hash OTP codes (email verification / password reset).
# Deliberately separate from JWT_SECRET so rotating one never invalidates the
# other. Keep this secret strong and unique per environment.
OTP_SECRET="change-me"

# App
PORT=3000
NODE_ENV=development

# ============================================
# Email (OTP delivery)
# ============================================
# "console" logs the email instead of sending it (default; zero AWS
# dependency for local dev). "ses" sends via Amazon SES — requires
# SES_SENDER_EMAIL and a verified SES identity (see
# infrastructure/terraform/modules/notifications).
EMAIL_PROVIDER=console

# Single verified SES sender identity. Required when EMAIL_PROVIDER=ses.
SES_SENDER_EMAIL=

# ============================================
# Storage (S3 / LocalStack)
# ============================================
# Storage backend. Currently only "s3" is implemented; it serves BOTH
# LocalStack and real AWS — the difference is purely AWS_ENDPOINT below.
# Future value: "cloudfront" (for CDN-signed download URLs).
STORAGE_PROVIDER=s3

AWS_REGION=eu-central-1

# LocalStack endpoint for local development. LEAVE EMPTY for real AWS.
AWS_ENDPOINT=http://localhost:4566

# Optional. Host used when building file URLs returned to clients. Defaults to
# AWS_ENDPOINT. Set to your machine's LAN IP (e.g. http://192.168.1.10:4566)
# when testing on a physical device, since the device can't reach "localhost".
# In production this is normally left empty (real S3 / CloudFront domain is used).
S3_PUBLIC_ENDPOINT=

# Credentials. For LocalStack any non-empty values work. For real AWS, PREFER
# an IAM role (ECS task role) and leave these empty.
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Bucket that stores all files (documents, photos, videos, attachments).
AWS_S3_BUCKET=keynest-local-documents

# Bucket for the static legal/support pages (privacy policy, terms, support).
# Deployed locally via `npm run legal:deploy` (LocalStack static hosting).
LEGAL_BUCKET=keynest-legal

# ============================================
# CloudFront (FUTURE — not implemented yet)
# ============================================
# When a CloudFront-aware storage provider is added, set STORAGE_PROVIDER=cloudfront
# and populate these. They are intentionally empty for now.
# AWS_CLOUDFRONT_DOMAIN=
# AWS_CLOUDFRONT_KEY_PAIR_ID=
# AWS_CLOUDFRONT_PRIVATE_KEY=

# Google Maps / Places
GOOGLE_MAPS_API_KEY=
