generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
}

enum DocumentCategory {
  // Property document categories
  INSURANCE
  WARRANTY
  METER_READING
  PROPERTY_PLAN // Floor plans / building plans (replaces the removed PROPERTY_PHOTO)
  INVOICE
  MANUAL
  // Lease document categories
  LEASE_AGREEMENT
  SIGNED_LEASE
  GUARANTOR_DOCUMENT
  ADDENDUM
  // Standardized categories (aligned with the document workflow)
  IDENTIFICATION
  LEGAL // Municipality / legal documents
  PROPERTY_INFO // General property information
  TENANT_DOCUMENT
  // Maintenance financial receipts (also linked via Document.maintenanceRequestId)
  RECEIPT
  // General/Legacy
  CONTRACT // Kept for backward compatibility
  OTHER
}

// Who can access a document. Extensible: future roles (e.g. co-owner, agent,
// guarantor) are added as new enum values without another schema redesign.
enum DocumentPermission {
  LANDLORD_ONLY // Only the property owner
  LANDLORD_AND_TENANT // Owner and the tenant
}

// System-provided folders that exist for every property and cannot be deleted.
// A stable key (rather than matching on name) so the client can translate the
// display label and the backend can enforce immutability.
enum SystemFolderKey {
  CONTRACTS
  RECEIPTS
  PROPERTY_PLANS
  INSURANCE
  MUNICIPALITY
  GENERAL
}

// Auditable document actions. Extensible: add a value + emit it from the
// corresponding service path; the DocumentAuditLog.metadata Json carries any
// action-specific detail (e.g. old/new name, source/target folder).
enum DocumentAuditAction {
  UPLOAD
  DELETE
  RENAME
  MOVE
  PERMISSION_CHANGE
  PREVIEW
  DOWNLOAD
  // AI platform events (PR3)
  AI_REQUESTED
  AI_COMPLETED
  AI_FAILED
  AI_SUGGESTION_ACCEPTED
  AI_CATEGORY_CHANGED
  AI_RETRIED
}

// Lifecycle of an asynchronous AI processing job.
enum AiJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

// Where a receipt originated. Extensible: future sources (e.g. EMAIL_IMPORT,
// BANK_FEED) are added as new values without a schema redesign.
enum ReceiptSource {
  MAINTENANCE
  MANUAL_UPLOAD
}

// Required-document workflow status.
enum DocumentStatus {
  OPTIONAL // A regular uploaded document (default)
  REQUESTED // Landlord requested this from the tenant; no file yet
  RECEIVED // Tenant has uploaded the requested file
}

enum LeaseStatus {
  PENDING
  ACTIVE
  ENDED
}

enum NotificationType {
  LEASE_PENDING
  LEASE_APPROVED
  LEASE_REJECTED
  LEASE_TERMS_UPDATED
  MAINTENANCE_CREATED
  MAINTENANCE_UPDATED
  MAINTENANCE_RESOLVED
  MAINTENANCE_COMMENT
  DOCUMENT_UPLOADED
  DOCUMENT_REQUESTED
  PASSWORD_CHANGED
}

// Purposes an OtpCode can be issued for. EMAIL_CHANGE is infrastructure-only
// for now (no endpoint uses it yet) — see User.pendingEmail.
enum OtpPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  EMAIL_CHANGE
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Email verification (OTP-based). Existing rows are backfilled to true by
  // the migration that introduces this column; only new registrations go
  // through the OTP flow.
  emailVerified     Boolean   @default(false)
  emailVerifiedAt   DateTime?
  lastLoginAt       DateTime?
  passwordChangedAt DateTime?
  phone             String?

  // Infrastructure for a future change-email feature (not implemented yet —
  // no endpoint sets these). Mirrors the Lease.activationCode/-ExpiresAt
  // pairing style already used elsewhere in this schema.
  pendingEmail          String?
  pendingEmailExpiresAt DateTime?

  // Avatar, via the shared StoredFile pipeline (mirrors PropertyMedia.storedFileId
  // — unique FK, RESTRICT so a file can't be deleted while still referenced as
  // someone's avatar). Only the FK is ever persisted; the signed download URL
  // is generated fresh on every read (see ProfileService.getProfile).
  avatarStoredFileId String?     @unique
  avatarStoredFile   StoredFile? @relation("UserAvatar", fields: [avatarStoredFileId], references: [id], onDelete: Restrict)

  otpCodes OtpCode[]

  // Relations
  ownedProperties     Property[]
  leases              Lease[]
  maintenanceRequests MaintenanceRequest[]
  maintenanceComments MaintenanceComment[]
  maintenanceReads    MaintenanceRead[]
  uploadedDocuments   Document[]
  createdFolders      Folder[]
  documentAuditLogs   DocumentAuditLog[]
  aiApprovals         AiClassification[]   @relation("AiApprovals")
  sessions            Session[]
  notifications       Notification[]

  // Media uploads (separate domains: property gallery vs. maintenance evidence)
  uploadedPropertyMedia          PropertyMedia[]
  uploadedMaintenanceAttachments MaintenanceAttachment[]
  uploadedStoredFiles            StoredFile[]            @relation("UploadedFiles")

  @@index([email])
}

// Single-use, short-lived OTP codes for email verification / password reset
// (and, in the future, email change — see OtpPurpose.EMAIL_CHANGE). One
// polymorphic table keyed by `purpose`, mirroring the Notification.type /
// Document.category precedent elsewhere in this schema, rather than a
// separate table per purpose.
model OtpCode {
  id         String     @id @default(cuid())
  purpose    OtpPurpose
  codeHash   String // HMAC-SHA256(OTP_SECRET, code) — not bcrypt; see OtpService
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int        @default(0)
  createdAt  DateTime   @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
  @@index([expiresAt])
  @@index([userId, purpose, createdAt])
}

model Session {
  id               String   @id @default(cuid())
  refreshTokenHash String
  deviceIdentifier String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  lastUsedAt       DateTime @default(now())
  expiresAt        DateTime

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Property {
  id           String   @id @default(cuid())
  title        String
  address      String // Legacy field, kept for backward compatibility
  city         String
  squareMeters Int
  rooms        Int
  floor        Int?
  hasBalcony   Boolean  @default(false)
  hasParking   Boolean  @default(false)
  hasStorage   Boolean  @default(false)
  hasShelter   Boolean  @default(false)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Structured location fields (from Google Places)
  formattedAddress String? // Full formatted address from Google
  street           String? // Street name
  streetNumber     String? // Street number
  latitude         Float? // Geographic latitude
  longitude        Float? // Geographic longitude
  placeId          String? // Google Place ID for reference

  // Owner relation
  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  // Relations
  leases              Lease[]
  documents           Document[]
  folders             Folder[]
  maintenanceRequests MaintenanceRequest[]
  media               PropertyMedia[]

  @@index([ownerId])
  @@index([city])
  @@index([placeId])
}

model Lease {
  id        String      @id @default(cuid())
  status    LeaseStatus @default(PENDING)
  startDate DateTime
  endDate   DateTime?
  // LEGACY — kept for backward compatibility only. Pricing lives in LeaseTerm;
  // this column mirrors the first term's rent so pre-existing readers keep
  // working. New code must read pricing through LeasePricingService, never
  // this column directly.
  monthlyRent   Decimal?  @db.Decimal(10, 2)
  depositAmount Decimal?  @db.Decimal(10, 2)
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Per-lease activation code. The landlord creates the lease (tenant-less) and
  // shares this code; a tenant redeems it to become the lease's tenant.
  // Cleared (consumed) once redeemed.
  activationCode          String?   @unique
  activationCodeExpiresAt DateTime?

  // Relations
  propertyId     String
  property       Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  // Nullable: a lease is the landlord's record and may be "Unassigned" until a
  // tenant redeems the activation code.
  tenantId       String?
  tenant         User?       @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  documents      Document[]
  // The lease's pricing schedule (see LeaseTerm).
  leaseTerms     LeaseTerm[]
  // Receipt metadata attributed to this lease (see Receipt).
  receiptRecords Receipt[]

  @@index([propertyId])
  @@index([tenantId])
  @@index([status])
}

// One pricing period of a lease's rent schedule. A lease's terms are
// contiguous, non-overlapping, sorted by startDate, and together cover the
// entire lease duration (enforced in LeasePricingService — the single home for
// all pricing logic; the DB only guarantees uniqueness of displayOrder).
// endDate is null only on the final term of an open-ended lease (mirrors
// Lease.endDate).
//
// Future-ready (no redesign needed): recurring charges (parking, storage,
// internet, municipal tax, …) attach as a child table keyed by leaseTermId;
// CPI linkage, discounts and pricing type become additional columns here.
model LeaseTerm {
  id           String    @id @default(cuid())
  startDate    DateTime
  endDate      DateTime? // null = open-ended (only allowed on the last term)
  monthlyRent  Decimal   @db.Decimal(10, 2)
  currency     String    @default("ILS") // ISO 4217 code
  notes        String?
  displayOrder Int
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  leaseId String
  lease   Lease  @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@unique([leaseId, displayOrder])
  @@index([leaseId])
  @@index([leaseId, startDate])
}

model Document {
  id          String             @id @default(cuid())
  name        String
  category    DocumentCategory
  permission  DocumentPermission @default(LANDLORD_ONLY)
  status      DocumentStatus     @default(OPTIONAL)
  requestedAt DateTime?
  receivedAt  DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  // Parent relations (exactly one of propertyId/leaseId must be set)
  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  leaseId    String?
  lease      Lease?    @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  // Optional cross-reference for a RECEIPT document (layered on top of the
  // propertyId/leaseId parent above, not a replacement for it) — lets a
  // future accounting module query every receipt directly via this FK
  // without scanning maintenance conversations.
  maintenanceRequestId String?
  maintenanceRequest   MaintenanceRequest? @relation(fields: [maintenanceRequestId], references: [id], onDelete: SetNull)

  // Uploader relation
  uploadedById String?
  uploadedBy   User?   @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  // Physical file (null for a REQUESTED document with no upload yet).
  storedFileId String?     @unique
  storedFile   StoredFile? @relation(fields: [storedFileId], references: [id], onDelete: SetNull)

  // Optional containing folder. Nullable: pre-existing documents (and any
  // document not filed into a folder) stay at the property/lease root.
  folderId String?
  folder   Folder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  auditLogs DocumentAuditLog[]

  // 1:1 receipt metadata (only for category RECEIPT documents). Sibling record,
  // so the Document model itself stays unchanged — see the Receipt model.
  receipt Receipt?

  // AI platform (PR3). All sibling records — the Document model is untouched by
  // AI logic; results attach here.
  aiJobs            AiJob[]
  aiSummary         AiSummary?
  aiClassification  AiClassification?
  aiExtractedFields AiExtractedField[]

  @@index([propertyId])
  @@index([leaseId])
  @@index([maintenanceRequestId])
  @@index([uploadedById])
  @@index([category])
  @@index([status])
  @@index([folderId])
}

// Receipt metadata attached 1:1 to a RECEIPT-category Document. The file itself
// lives on the Document/StoredFile (never duplicated); this row carries the
// tax/accounting facts. Designed as the seam for a future accounting module:
// add amount/currency/vat/category columns later without a redesign, and query
// across properties via Document.propertyId (taxYear/source are indexed).
model Receipt {
  id          String        @id @default(cuid())
  receiptDate DateTime? // As stated on the receipt; null falls back to upload date for taxYear.
  taxYear     Int // Derived once at creation (receiptDate year, else upload year).
  source      ReceiptSource
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // The document (and its file) this receipt describes.
  documentId String   @unique
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  // Optional links to the business entities the expense relates to.
  relatedMaintenanceId String?
  relatedMaintenance   MaintenanceRequest? @relation(fields: [relatedMaintenanceId], references: [id], onDelete: SetNull)
  relatedLeaseId       String?
  relatedLease         Lease?              @relation(fields: [relatedLeaseId], references: [id], onDelete: SetNull)

  @@index([taxYear])
  @@index([source])
  @@index([relatedLeaseId])
  @@index([relatedMaintenanceId])
}

// ============================================================================
// AI platform (PR3)
// ============================================================================
// Provider/model are stored as strings (not enums) so new providers plug in
// without a schema change. Business services talk to the AIProvider
// abstraction, never to a specific provider.

// One asynchronous analysis attempt for a document. Multiple rows per document
// accumulate over reprocessing/retries; the latest drives the UI status.
model AiJob {
  id           String      @id @default(cuid())
  provider     String
  model        String
  status       AiJobStatus @default(QUEUED)
  attempts     Int         @default(0)
  startedAt    DateTime?
  completedAt  DateTime?
  errorMessage String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([status])
}

// One concise human-readable summary per document (latest successful analysis).
model AiSummary {
  id        String   @id @default(cuid())
  text      String
  provider  String
  model     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documentId String   @unique
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

// AI category prediction + the user's approval. The predicted* fields are
// written by AI; the approved* fields are written only by the user. AI must
// NEVER overwrite approved* — the user's decision always wins, and the original
// prediction is retained for analytics.
model AiClassification {
  id                String            @id @default(cuid())
  predictedCategory DocumentCategory
  confidence        Float
  approvedCategory  DocumentCategory?
  approvedAt        DateTime?
  provider          String
  model             String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  documentId String   @unique
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  approvedById String?
  approvedBy   User?   @relation("AiApprovals", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([approvedById])
}

// Normalized AI-extracted metadata: one row per field. `key` is a free string
// (e.g. "supplier", "invoiceNumber", "amount") so new fields need no migration.
// Typed value columns keep it query/search-ready without JSON blobs.
model AiExtractedField {
  id          String    @id @default(cuid())
  key         String
  valueText   String?
  valueNumber Decimal?  @db.Decimal(14, 2)
  valueDate   DateTime?
  confidence  Float?
  createdAt   DateTime  @default(now())

  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([key])
}

// A folder within a property's document tree. Folders nest via `parentId`.
// Six system folders (isSystem = true, one per SystemFolderKey) are created for
// every property and cannot be renamed, moved, or deleted.
model Folder {
  id        String           @id @default(cuid())
  name      String
  isSystem  Boolean          @default(false)
  // Set only for system folders; null for user-created folders.
  systemKey SystemFolderKey?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  // Self-relation for nesting. Deleting a folder cascades to its children.
  parentId String?
  parent   Folder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children Folder[] @relation("FolderTree")

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  documents Document[]

  @@index([propertyId])
  @@index([parentId])
}

// Append-only audit trail of document actions. documentId/actorId are
// SetNull-nullable so a log row survives deletion of the document or user it
// references. `metadata` carries action-specific detail without new columns.
model DocumentAuditLog {
  id        String              @id @default(cuid())
  action    DocumentAuditAction
  metadata  Json?
  createdAt DateTime            @default(now())

  documentId String?
  document   Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  // Denormalized so the property's audit history is queryable even after the
  // document row is deleted.
  propertyId String?

  actorId String?
  actor   User?   @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([documentId])
  @@index([propertyId])
  @@index([actorId])
}

model MaintenanceRequest {
  id          String            @id @default(cuid())
  title       String
  description String
  status      MaintenanceStatus @default(OPEN)
  priority    Int               @default(1)
  resolvedAt  DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Relations
  propertyId     String
  property       Property                @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  requesterId    String
  requester      User                    @relation(fields: [requesterId], references: [id], onDelete: Cascade)
  comments       MaintenanceComment[]
  attachments    MaintenanceAttachment[]
  reads          MaintenanceRead[]
  // Financial receipts uploaded once this request is RESOLVED — each is a
  // first-class Document (category RECEIPT), not a maintenance-only record.
  receipts       Document[]
  // Receipt metadata attributed to this request (see Receipt).
  receiptRecords Receipt[]

  @@index([propertyId])
  @@index([requesterId])
  @@index([status])
}

// Tracks when a user last opened a maintenance request's conversation.
// Powers "suppress notification if recently active" and "mark read on open".
model MaintenanceRead {
  id         String   @id @default(cuid())
  lastReadAt DateTime @default(now())

  requestId String
  request   MaintenanceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([requestId, userId])
  @@index([userId])
}

model MaintenanceComment {
  id        String   @id @default(cuid())
  // Nullable: a message may be attachment-only (see MaintenanceAttachment.commentId).
  body      String?
  createdAt DateTime @default(now())

  // Relations
  requestId String
  request   MaintenanceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  authorId  String
  author    User               @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // The file attached to this specific message, if any (distinct from the
  // request-level attachments below, which have commentId = null).
  attachment MaintenanceAttachment?

  @@index([requestId])
  @@index([authorId])
}

// Property gallery media (photos/videos of the property itself).
// A distinct domain model from MaintenanceAttachment by design.
model PropertyMedia {
  id        String    @id @default(cuid())
  type      MediaType
  createdAt DateTime  @default(now())

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  uploadedById String?
  uploadedBy   User?   @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  storedFileId String     @unique
  storedFile   StoredFile @relation(fields: [storedFileId], references: [id], onDelete: Restrict)

  @@index([propertyId])
  @@index([uploadedById])
}

// Evidence files attached to a maintenance request.
// A distinct domain model from PropertyMedia by design.
model MaintenanceAttachment {
  id        String    @id @default(cuid())
  type      MediaType
  createdAt DateTime  @default(now())

  maintenanceRequestId String
  maintenanceRequest   MaintenanceRequest @relation(fields: [maintenanceRequestId], references: [id], onDelete: Cascade)

  // Set when this attachment belongs to a specific chat message rather than
  // being a general request-level evidence upload (null = the pre-existing
  // behavior, shown in the request's top-level attachments list).
  commentId String?             @unique
  comment   MaintenanceComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  uploadedById String?
  uploadedBy   User?   @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  storedFileId String     @unique
  storedFile   StoredFile @relation(fields: [storedFileId], references: [id], onDelete: Restrict)

  @@index([maintenanceRequestId])
  @@index([uploadedById])
}

// ============================================================================
// Media / Storage layer
// ============================================================================
// A physical file stored in the storage backend (S3 / LocalStack today).
//
// StoredFile holds ONLY storage metadata — it has no business meaning and does
// not know *why* it exists. Business entities (Document, PropertyMedia,
// MaintenanceAttachment, future LeaseDocument / InspectionReport / Signature)
// reference it via a `storedFileId` FK. The back-relations below exist purely
// for Prisma navigation + referential integrity, not business logic.
//
// Future-ready (no redesign needed): versioning (storageVersion), thumbnails /
// dimensions (imageWidth/Height, videoDuration), checksums, multi-provider
// (storageProvider), and multiple files per entity (add a join on the owner side).
model StoredFile {
  id               String   @id @default(cuid())
  storageKey       String   @unique // path within the bucket; never the original filename
  originalFilename String // display name shown to users
  mimeType         String
  fileExtension    String?
  fileSize         Int
  checksum         String?
  imageWidth       Int?
  imageHeight      Int?
  videoDuration    Int? // seconds
  storageProvider  String   @default("s3")
  storageVersion   String? // future: object version id
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  uploadedById String?
  uploadedBy   User?   @relation("UploadedFiles", fields: [uploadedById], references: [id], onDelete: SetNull)

  // Navigation-only inverse relations (Prisma requirement); no business logic.
  document              Document?
  propertyMedia         PropertyMedia?
  maintenanceAttachment MaintenanceAttachment?
  avatarOfUser          User?                  @relation("UserAvatar")

  @@index([uploadedById])
}

model Notification {
  id         String           @id @default(cuid())
  type       NotificationType
  title      String
  message    String
  isRead     Boolean          @default(false)
  entityType String? // e.g., "lease", "property", "maintenance"
  entityId   String? // ID of the related entity
  createdAt  DateTime         @default(now())

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
}
