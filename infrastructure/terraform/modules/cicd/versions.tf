# CI/CD module — provider requirements.
# `tls` is used (data-only, no config) to derive the GitHub OIDC thumbprint.

terraform {
  required_version = ">= 1.6.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.60"
    }
    tls = {
      source  = "hashicorp/tls"
      version = "~> 4.0"
    }
  }
}
